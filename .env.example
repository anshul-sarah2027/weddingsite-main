# Supabase (required for RSVP submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dashboard (couple-only RSVP admin)
# Find service_role in Supabase → Project Settings → API Keys (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Guest site gate + couple dashboard (same shared password)
# Guests enter this once; access is remembered for 24 hours.
DASHBOARD_PASSWORD=choose-a-strong-password

# RSVP confirmation emails (Resend — https://resend.com)
# Without RESEND_API_KEY, RSVPs still save; confirmation email is skipped.
RESEND_API_KEY=re_xxxxxxxx
# Must be a verified sender/domain in Resend. For testing you can use:
# RESEND_FROM_EMAIL=Sarah & Anshul <onboarding@resend.dev>
RESEND_FROM_EMAIL=Sarah & Anshul <rsvp@sarahandanshul.com>

# Cron protection (Vercel Cron Jobs — see vercel.json)
# Set this in Vercel's project env vars too. Vercel automatically sends it as
# "Authorization: Bearer <CRON_SECRET>" on requests it triggers from cron.
# Used by /api/health (Supabase keep-alive) and /api/cron/rsvp-reminder.
CRON_SECRET=choose-a-long-random-string
